# Copia este archivo como .env.local y pon tus valores.
# NUNCA subas .env.local a GitHub (ya está en .gitignore).

# API key de YouTube Data v3 - obtener en https://console.cloud.google.com/
# Sin el prefijo NEXT_PUBLIC_ → solo accesible desde el servidor (más seguro)
YOUTUBE_API_KEY=

# URL del feed RSS de LinkedIn (generado en rss.app)
LINKEDIN_RSS_URL=https://rss.app/feeds/ncqqzQD5qCRcpNTf.xml

# ID de la playlist de YouTube
YOUTUBE_PLAYLIST_ID=PLkoFClbNd6NDy0GUQuY5p3eDQm3qnYKqH

# Subdominio de la wiki de Fandom
FANDOM_WIKI=superthings

# Término de búsqueda para Google News
NEWS_QUERY=Superthings La Película
